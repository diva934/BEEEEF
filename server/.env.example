# ─────────────────────────────────────────────────────────────
#  BEEEF Backend — variables d'environnement
#  Copie ce fichier en .env pour le développement local.
#  Sur Render : renseigne ces variables dans Dashboard → Environment
# ─────────────────────────────────────────────────────────────

# Serveur
# Render fournit PORT automatiquement. Garde 3001 uniquement pour le dev local.
PORT=3001
NODE_ENV=production

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── CORS ────────────────────────────────────────────────────
# Sépare plusieurs origines par des virgules
ALLOWED_ORIGINS=https://beeeef.vercel.app
# Mettre true seulement si tu veux autoriser les previews Vercel
ALLOW_VERCEL_PREVIEWS=false

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://beeeef.vercel.app/?paid=ok&session={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://beeeef.vercel.app/?paid=cancel

# ── Resend (emails transactionnels) ─────────────────────────
RESEND_API_KEY=re_...
GIFT_ORDERS_ADMIN_EMAIL=admin@email.com
ADMIN_EMAIL=admin@email.com

# ── Tremendous (cartes cadeaux) ─────────────────────────────
TREMENDOUS_API_KEY=TEST_...
TREMENDOUS_ENV=sandbox
# TREMENDOUS_FUNDING_ID=  # auto-détecté si vide
# TREMENDOUS_PRODUCT_APPLE=RNMA
# TREMENDOUS_PRODUCT_AMAZON=QNQZC
# TREMENDOUS_PRODUCT_NETFLIX=RTTB
# TREMENDOUS_PRODUCT_SPOTIFY=SBUH
# TREMENDOUS_PRODUCT_PLAYSTATION=WDLD
# TREMENDOUS_PRODUCT_XBOX=WDKD
# TREMENDOUS_PRODUCT_EPIC=   # non dispo par défaut, à renseigner

# ── Optionnel / tuning ──────────────────────────────────────
# DEBATE_TARGET_ACTIVE_PER_REGION=30
# PREPARED_PREDICTIONS_PER_REGION=8
# PREDICTION_POLL_INTERVAL_MS=10000
# PREDICTION_VALIDATION_WINDOW_MS=60000
# NEWS_MAX_AGE_HOURS=36
# NEWS_FETCH_RETRIES=2
